#!/usr/bin/env node
// Thin trampoline: resolves the failure binary from the matching per-platform
// optional dependency package and execs it.
//
// Falls back to bootstrapping the canonical ~/.failure/bin/failure-<version> symlink
// layout if postinstall hasn't run (e.g. npx, or postinstall failure).
//
// Binary location strategy (in priority order):
//   1. ~/.failure/bin/failure        — canonical versioned symlink (postinstall.js)
//   2. @failure-build/failure-<platform>/bin/failure[.exe]      — decompressed sibling
//   3. @failure-build/failure-<platform>/bin/failure[.exe].br   — brotli-compressed
//
// Per-platform binaries are shipped brotli-compressed to stay well under
// npm's ~200 MB tarball ceiling. See sibling packages @failure-build/failure-*.
const { spawn } = require('child_process');
const path = require('path');
const fs = require('fs');
const os = require('os');
const zlib = require('zlib');

const pkgName = '@failure-build/failure';
const IS_WINDOWS = process.platform === 'win32';
const EXE = IS_WINDOWS ? '.exe' : '';
const BIN_NAME = `failure${EXE}`;
const CANONICAL_DIR = path.join(os.homedir(), '.failure', 'bin');
const CANONICAL_PATH = path.join(CANONICAL_DIR, BIN_NAME);

function readLocalVersion() {
    try { return require('../package.json').version; } catch { return undefined; }
}

function resolvePlatformPackageDir() {
    const platformPkg = `@failure-build/failure-${process.platform}-${process.arch}`;
    try {
        return path.dirname(require.resolve(`${platformPkg}/package.json`));
    } catch {
        return null;
    }
}

function decompressBrotli(brPath, outPath) {
    const compressed = fs.readFileSync(brPath);
    const decompressed = zlib.brotliDecompressSync(compressed);
    const tmp = outPath + `.tmp.${process.pid}`;
    fs.writeFileSync(tmp, decompressed);
    if (!IS_WINDOWS) fs.chmodSync(tmp, 0o755);
    try { fs.renameSync(tmp, outPath); } catch {}
}

function bootstrapCanonical(sourceBinPath, version) {
    try {
        fs.mkdirSync(CANONICAL_DIR, { recursive: true });
        const versionedName = `failure-${version}${EXE}`;
        const versionedPath = path.join(CANONICAL_DIR, versionedName);
        if (!fs.existsSync(versionedPath)) {
            const tmpPath = versionedPath + `.tmp.${process.pid}`;
            fs.copyFileSync(sourceBinPath, tmpPath);
            if (!IS_WINDOWS) fs.chmodSync(tmpPath, 0o755);
            fs.renameSync(tmpPath, versionedPath);
        }
        if (IS_WINDOWS) {
            const oldPath = CANONICAL_PATH + '.old';
            try { fs.unlinkSync(oldPath); } catch {}
            try {
                try { fs.unlinkSync(CANONICAL_PATH); } catch {}
                fs.copyFileSync(versionedPath, CANONICAL_PATH);
            } catch {
                fs.renameSync(CANONICAL_PATH, oldPath);
                try {
                    fs.copyFileSync(versionedPath, CANONICAL_PATH);
                } catch {
                    try { fs.renameSync(oldPath, CANONICAL_PATH); } catch {}
                    throw new Error('locked');
                }
            }
        } else {
            const tmpLink = CANONICAL_PATH + `.link.${process.pid}`;
            try { fs.unlinkSync(tmpLink); } catch {}
            fs.symlinkSync(versionedName, tmpLink);
            fs.renameSync(tmpLink, CANONICAL_PATH);
        }
        return CANONICAL_PATH;
    } catch {
        return sourceBinPath;
    }
}

function resolveBinary() {
    if (fs.existsSync(CANONICAL_PATH)) return CANONICAL_PATH;

    const platformDir = resolvePlatformPackageDir();
    if (!platformDir) {
        console.error(`${pkgName}: no platform binary installed for ${process.platform}-${process.arch}.`);
        console.error(`  Expected sibling package @failure-build/failure-${process.platform}-${process.arch}.`);
        console.error(`  This usually means npm skipped optionalDependencies (e.g. --no-optional)`);
        console.error(`  or the platform is not supported.`);
        process.exit(1);
    }

    const rawPath = path.join(platformDir, 'bin', BIN_NAME);
    const brPath = rawPath + '.br';
    if (!fs.existsSync(rawPath) && fs.existsSync(brPath)) {
        decompressBrotli(brPath, rawPath);
    }
    if (!fs.existsSync(rawPath)) {
        console.error(`${pkgName}: missing binary at ${rawPath}`);
        process.exit(1);
    }

    const version = readLocalVersion();
    return version ? bootstrapCanonical(rawPath, version) : rawPath;
}

function shouldStartMcp() {
    if (process.env.FAILURE_MCP_CHILD === '1') return false;
    if (process.env.FAILURE_MCP_ENABLED === '0') return false;

    const first = process.argv[2];
    const skip = new Set([
        'completions', 'export', 'inspect', 'login', 'logout', 'mcp', 'memory',
        'models', 'plugin', 'sessions', 'setup', 'trace', 'update', 'version',
        'worktree', '--help', '-h', '--version', '-v',
    ]);
    return !first || !skip.has(first);
}

function startMcpBridge() {
    if (!shouldStartMcp()) return null;
    const script = path.join(__dirname, 'mcp-server.js');
    if (!fs.existsSync(script)) return null;

    // Point the bridge back at this launcher, not directly at the native binary.
    // FAILURE_MCP_CHILD prevents recursion, while keeping package resolution and
    // command compatibility centralized in one place.
    const child = spawn(process.execPath, [script, '--failure-bin', __filename], {
        stdio: ['ignore', 'ignore', 'inherit'],
        env: { ...process.env, FAILURE_BIN: __filename },
        windowsHide: true,
    });
    child.on('error', (error) => {
        console.error(`${pkgName}: MCP bridge failed to start: ${error.message}`);
    });
    return child;
}

function forwardedArgs() {
    const args = process.argv.slice(2);
    // The MCP bridge historically requested a JSON session listing. The native
    // command now requires an explicit `list` subcommand and prints stable text.
    // Translate the compatibility form here so older bridge builds still work.
    if (
        process.env.FAILURE_MCP_CHILD === '1'
        && args.length === 2
        && args[0] === 'sessions'
        && args[1] === '--json'
    ) {
        return ['sessions', 'list'];
    }
    return args;
}

const execPath = resolveBinary();
const mcp = startMcpBridge();
const childEnv = { ...process.env, FAILURE_MANAGED_BY_NPM: '1' };
const child = spawn(execPath, forwardedArgs(), { stdio: 'inherit', env: childEnv });

function stopMcp() {
    if (!mcp || mcp.killed) return;
    try { mcp.kill(); } catch {}
}

child.on('exit', (code, signal) => {
    stopMcp();
    if (signal) {
        process.kill(process.pid, signal);
    } else {
        process.exit(code ?? 0);
    }
});
child.on('error', (error) => {
    stopMcp();
    console.error(`${pkgName}: failed to launch Failure: ${error.message}`);
    process.exit(1);
});
process.on('SIGINT', stopMcp);
process.on('SIGTERM', stopMcp);
process.on('exit', stopMcp);
